# LeadIQ — Environment Variables Template
# Copy this file to .env.local (frontend) or .env (backend)
# NEVER commit .env.local or .env to version control

# ── DATABASE ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://leadiq:leadiq@localhost:5432/leadiq
# PostgreSQL connection string with asyncpg driver
# Format: postgresql+asyncpg://user:password@host:port/database

# ── REDIS ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
# Redis connection URL for caching and message queues
# Format: redis://[:password]@localhost:6379

# ── GEMINI / GCP ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=
# Google Gemini API key from AI Studio (https://aistudio.google.com/app/apikey)
# Leave blank to skip AI analysis

GEMINI_MODEL=gemini-2.0-flash
# Gemini model to use: gemini-2.0-flash (default), gemini-2.0-flash-lite, gemini-1.5-pro

GCP_PROJECT_ID=
# GCP Project ID for Vertex AI (alternative to API key)
# Required if using GCP service account authentication

GCP_LOCATION=us-central1
# GCP region for Vertex AI API calls

# ── AUTH ───────────────────────────────────────────────────────────────────────
JWT_SECRET_KEY=
# 32+ character random secret for JWT signing (generate with: openssl rand -hex 32)

JWT_ALGORITHM=HS256
# JWT signing algorithm (HS256, RS256, etc.)

JWT_ACCESS_TOKEN_EXPIRE_MINUTES=480
# Access token expiry in minutes (default: 8 hours)

JWT_REFRESH_TOKEN_EXPIRE_DAYS=30
# Refresh token expiry in days

SECRET_KEY=
# Flask-style secret key for session management

ADMIN_USERNAME=admin
# Admin username for admin endpoints

ADMIN_PASSWORD=
# Admin password (required in production)

# ── APIS ───────────────────────────────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=LeadIQ/1.0
# Reddit API credentials for scraping (https://www.reddit.com/prefs/apps)

TWITTER_BEARER_TOKEN=
# Twitter API bearer token (https://developer.twitter.com/en/portal/dashboard)

GITHUB_TOKEN=
# GitHub personal access token (5000 req/hour with auth)
# Generate at: https://github.com/settings/tokens

HUNTER_API_KEY=
# Hunter.io API key for email verification (https://hunter.io/api-keys)

CLEARBIT_API_KEY=
# Clearbit API key for company enrichment (https://dashboard.clearbit.com/api-keys)

# ── TELEGRAM ACTOR ─────────────────────────────────────────────────────────────
TELEGRAM_WATCHED_CHANNELS=@inc42,@startupsindia,@yourstory
# Comma-separated public Telegram channel usernames (no bot required)
# Channels are scraped via t.me/s/ to find funding/hiring signals

# ── MONITORING ─────────────────────────────────────────────────────────────────
SENTRY_DSN=
# Sentry project DSN for error tracking
# Get from: https://sentry.io/settings/organizations/{org}/projects/{project}/keys/

LOG_LEVEL=INFO
# Logging level: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ── RATE LIMITING ──────────────────────────────────────────────────────────────
RATE_LIMIT_DEFAULT=120/minute
# Default rate limit for all endpoints

RATE_LIMIT_AUTH=10/minute
# Rate limit for authentication endpoints

RATE_LIMIT_EXPENSIVE=5/minute
# Rate limit for expensive operations (LLM, API calls)

# ── CELERY ─────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
# Redis URL for Celery message broker

CELERY_RESULT_BACKEND=redis://localhost:6379/2
# Redis URL for Celery result backend

# ── REDIS STREAMS ──────────────────────────────────────────────────────────────
STREAM_COLLECTED=lead:collected
STREAM_ANALYZED=lead:analyzed
STREAM_SCORED=lead:scored
STREAM_RANKED=lead:ranked
STREAM_OUTREACH=lead:outreach
STREAM_CRM_UPDATE=lead:crm_update
STREAM_LOGS=system:logs
# Redis stream names for the event bus pipeline

# ── MCP ────────────────────────────────────────────────────────────────────────
MCP_API_KEY=
# Optional API key to protect /mcp endpoint (empty = dev mode, no auth)

# ── CORS ───────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000"]
# JSON array of allowed CORS origins
# Format: ["http://localhost:3000", "https://yourdomain.com"]

# ── FRONTEND (Next.js) ────────────────────────────────────────────────────────
# These go in .env.local (frontend)
NEXT_PUBLIC_API_URL=http://localhost:8000
# URL of the backend FastAPI server

# ── APP ────────────────────────────────────────────────────────────────────────
APP_NAME=LeadIQ
# Application name for logging/debugging

DEBUG=False
# Enable debug mode (set to True for development)
