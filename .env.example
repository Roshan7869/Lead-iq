# ─────────────────────────────────────────────────────────────
#  LeadIQ — Environment Variables
#  Copy this file to .env.local (frontend) and .env (backend).
#  NEVER commit .env.local or .env to version control.
# ─────────────────────────────────────────────────────────────

# ── Frontend (Next.js) ────────────────────────────────────────
# URL of the backend FastAPI server (used by the frontend API calls)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Backend (FastAPI) ─────────────────────────────────────────
# Redis connection URL
REDIS_URL=redis://localhost:6379

# PostgreSQL connection URL (asyncpg driver for async FastAPI)
DATABASE_URL=postgresql+asyncpg://leadiq:leadiq@localhost:5432/leadiq

# CORS: JSON array of allowed origins
ALLOWED_ORIGINS=["http://localhost:3000"]

# Toggle debug mode (set to False in production)
DEBUG=False

# ── Gemini LLM via GCP ────────────────────────────────────────
# The AI Analyzer worker supports two auth modes. Pick ONE:
#
# Mode 1 — Direct API key (Google AI Studio, simplest):
#   1. Go to https://aistudio.google.com/app/apikey
#   2. Create an API key and paste it below
GEMINI_API_KEY=

# Mode 2 — Vertex AI / GCP (recommended for production):
#   1. Enable the "Vertex AI API" in your GCP project
#   2. Create a service account with "Vertex AI User" role
#   3. Download the JSON key and set GOOGLE_APPLICATION_CREDENTIALS
#      OR run `gcloud auth application-default login`
GCP_PROJECT_ID=
GCP_LOCATION=us-central1

# Gemini model to use:
#   gemini-2.0-flash  — fastest & cheapest (recommended for development)
#   gemini-1.5-pro    — highest quality
#   gemini-1.5-flash  — balanced
GEMINI_MODEL=gemini-2.0-flash

# When running with Vertex AI, also set this to your service account key file:
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── Auth (future) ─────────────────────────────────────────────
# Secret key for JWT signing (generate with: openssl rand -hex 32)
# SECRET_KEY=your-secret-key-here
