# ─────────────────────────────────────────────────────────────
#  LeadIQ — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  NEVER commit .env.local to version control.
# ─────────────────────────────────────────────────────────────

# ── Frontend (Next.js) ────────────────────────────────────────
# URL of the backend FastAPI server (used by the frontend API calls)
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Backend (FastAPI) ─────────────────────────────────────────
# Redis connection URL
REDIS_URL=redis://localhost:6379

# PostgreSQL connection URL (asyncpg driver for async FastAPI)
DATABASE_URL=postgresql+asyncpg://leadiq:leadiq@localhost:5432/leadiq

# CORS: comma-separated list of allowed origins in JSON array format
ALLOWED_ORIGINS=["http://localhost:3000"]

# Toggle debug mode (set to False in production)
DEBUG=False

# ── Optional: AI / LLM Integration ───────────────────────────
# OpenAI API key (for Phase 4 AI Analyzer when wired up)
# OPENAI_API_KEY=sk-...

# ── Optional: Auth ────────────────────────────────────────────
# Secret key for JWT signing (generate with: openssl rand -hex 32)
# SECRET_KEY=your-secret-key-here
